{
  "name": "juliana-website",
  "version": "1.0.0",
  "description": "my website",
  "main": "index.html",
  "scripts": {
    "build": "sass --load-path=node_modules styles/main.scss:public/main.css",
    "watch": "sass --watch --load-path=node_modules styles/main.scss:public/main.css",
    "dev": "npm run build && wrangler dev",
    "deploy": "npm run build && wrangler deploy"
  },
